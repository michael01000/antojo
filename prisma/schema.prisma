// Antojo — Colombia-first food delivery platform
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  password  String?  // null for OAuth-only accounts
  name      String
  role      String   @default("cliente") // cliente | domiciliario | restaurante | admin
  avatarColor String @default("antojo")
  city      String   @default("Bogotá")
  provider  String   @default("email") // email | google | apple | phone
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  customer  Customer?
  driver    Driver?
  restaurant Restaurant?
  notifications Notification[]
}

model Customer {
  id          String   @id @default(cuid())
  userId      String?  @unique
  name        String
  email       String   @unique
  phone       String?
  city        String   @default("Bogotá")
  avatarColor String   @default("coral")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]  @relation("CustomerOrders")
  reviews     Review[]
  loyalty     LoyaltyAccount?
  subscription Subscription?
  addresses   Address[]
  favorites   Favorite[]
  follows     Follow[]
  postLikes   PostLike[]
  storyViews  StoryView[]
  groupOrders GroupOrder[] @relation("GroupOrderHost")
  // Fase 2: Programa de Referidos
  referralCode     String?  @unique
  referredByCode   String?  // código de quien lo refirió
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String
  street     String
  details    String?
  lat        Float    @default(4.6564)
  lng        Float    @default(-74.0579)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Restaurant {
  id           String     @id @default(cuid())
  userId      String?  @unique
  name         String
  slug         String     @unique
  description  String
  cuisine      String
  city         String     @default("Bogotá")
  neighborhood String
  rating       Float      @default(4.6)
  reviewCount  Int        @default(0)
  deliveryFee  Int        @default(3500)
  deliveryMin  Int        @default(25)
  priceLevel   Int        @default(2)
  imageUrl     String
  coverColor   String
  isOpen       Boolean    @default(true)
  isApproved   Boolean    @default(true)
  promo        String?
  tags         String     @default("")
  accentColor  String     @default("coral")
  ownerName   String?
  ownerPhone  String?
  createdAt    DateTime   @default(now())
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]
  orders       Order[]
  reviews      Review[]
  favorites    Favorite[]
  follows      Follow[]
  posts        Post[]
  stories      Story[]
  chefDrops    ChefDrop[]
  // Antojo Ads + monetización
  adsPlan       String   @default("free") // free | pro | premium
  adsRenewsAt   DateTime?
  sponsoredPostsUsed   Int      @default(0)
  sponsoredPostsResetAt DateTime?
  // Promo PYMES (2 meses sin comisión)
  pymePromoUntil  DateTime?
  lastPostAt      DateTime?
}

model MenuItem {
  id           String      @id @default(cuid())
  restaurantId String
  name         String
  description  String
  price        Int
  category     String
  imageUrl     String?
  emoji        String?
  isPopular    Boolean     @default(false)
  isAvailable  Boolean     @default(true)
  calories     Int?
  prepMin      Int?
  tags         String      @default("")
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  posts        Post[]
  stories      Story[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String?
  name       String
  emoji      String?
  price      Int
  qty        Int
  notes      String?
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
}

model Driver {
  id            String   @id @default(cuid())
  userId       String?  @unique
  name          String
  phone         String?
  vehicle       String   @default("Moto")
  plate         String?
  rating        Float    @default(4.9)
  city          String   @default("Bogotá")
  isOnline      Boolean  @default(false)
  isVerified   Boolean  @default(true)
  avatarColor   String   @default("green")
  earningsToday Int      @default(0)
  completedToday Int     @default(0)
  currentOrderId String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  // Gamificación
  bonusEarnedToday Int   @default(0)
  lastBonusTier    Int   @default(0)
  // Ledger de efectivo: saldo que el domiciliario debe consignar a la plataforma
  // (pedidos en efectivo donde recibió el dinero físico del cliente).
  // Si supera CASH_OWNED_LIMIT, no puede recibir más pedidos en efectivo.
  cashOwed         Int   @default(0)
}

model Order {
  id           String         @id @default(cuid())
  code         String         @unique
  customerId   String
  restaurantId String
  driverId     String?
  status       String         @default("placed")
  items        OrderItem[]
  subtotal     Int
  deliveryFee  Int
  serviceFee   Int
  discount     Int            @default(0)
  tip          Int            @default(0)
  total        Int
  paymentMethod String        @default("Tarjeta")
  address      String
  notes        String?
  isGroup      Boolean        @default(false)
  etaMin       Int            @default(35)
  rating       Int?
  driverLat    Float          @default(4.6564)
  driverLng    Float          @default(-74.0579)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // Fase 2: Programar pedidos
  scheduledFor DateTime?
  // Fase 3: Propina post-entrega
  tipPostDelivery Int         @default(0)
  // Fase 4: Mood ordering
  mood         String?        // happy | tired | sick | healthy | celebratory
  customer     Customer       @relation("CustomerOrders", fields: [customerId], references: [id])
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id])
  driver       Driver?        @relation(fields: [driverId], references: [id])
  events       OrderEvent[]
  messages     ChatMessage[]
  review       Review?
}

model OrderEvent {
  id      String   @id @default(cuid())
  orderId String
  status  String
  label   String
  at      DateTime @default(now())
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id      String   @id @default(cuid())
  orderId String
  sender  String
  text    String
  at      DateTime @default(now())
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id            String   @id @default(cuid())
  orderId       String   @unique
  customerId    String
  restaurantId  String
  rating        Int
  comment       String?
  foodRating    Int?
  deliveryRating Int?
  photoUrl      String?
  at            DateTime @default(now())
  // Fase 2: Respuesta del restaurante
  restaurantReply     String?
  restaurantReplyAt   DateTime?
  customer      Customer @relation(fields: [customerId], references: [id])
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  order         Order    @relation(fields: [orderId], references: [id])
  photos        ReviewPhoto[]
}

model LoyaltyAccount {
  id             String   @id @default(cuid())
  customerId     String   @unique
  coins          Int      @default(120)
  tier           String   @default("Plata")
  streakDays     Int      @default(3)
  challengesJson String   @default("[]")
  customer       Customer @relation(fields: [customerId], references: [id])
}

model Subscription {
  id         String    @id @default(cuid())
  customerId String    @unique
  plan       String    @default("prime")
  status     String    @default("active")
  renewsAt   DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id])
}

model Promotion {
  id              String  @id @default(cuid())
  code            String  @unique
  title           String
  description     String
  type            String    // percent | fixed | free_delivery
  value           Int
  minOrder        Int     @default(0)
  fundedBy        String  @default("restaurant") // restaurant | antojo — quién asume el descuento
  active          Boolean @default(true)
  uses            Int     @default(0)
  // ─── Sistema de Recompensas (cupones COIN-XXXX) ───
  ownerCustomerId String?   // si es un cupón canjeado con coins, a quién pertenece
  used            Boolean  @default(false) // si ya fue usado en un pedido
}

model GroupOrder {
  id              String    @id @default(cuid())
  code            String    @unique
  hostId          String
  restaurantId    String
  hostName        String    @default("")
  status          String    @default("open") // open | locked | ordered | expired
  participantsJson String   @default("[]")
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  host            Customer  @relation("GroupOrderHost", fields: [hostId], references: [id])
  items           GroupOrderItem[]
}

model GroupOrderItem {
  id              String   @id @default(cuid())
  groupOrderId    String
  addedByName     String
  menuItemId      String?
  name            String
  emoji           String?
  price           Int
  qty             Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())
  groupOrder      GroupOrder @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
}

model Follow {
  id           String    @id @default(cuid())
  customerId   String
  restaurantId String
  createdAt    DateTime  @default(now())
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  @@unique([customerId, restaurantId])
}

model Post {
  id           String    @id @default(cuid())
  restaurantId String
  imageUrl     String
  caption      String
  menuItemId   String?
  isSponsored  Boolean   @default(false)
  sponsoredUntil DateTime?
  likes        Int       @default(0)
  createdAt    DateTime  @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id])
  postLikes    PostLike[]
}

model PostLike {
  id         String   @id @default(cuid())
  postId     String
  customerId String
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@unique([postId, customerId])
}

model Story {
  id           String   @id @default(cuid())
  restaurantId String
  imageUrl     String
  caption      String?
  menuItemId   String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id])
  views        StoryView[]
}

model StoryView {
  id         String   @id @default(cuid())
  storyId    String
  customerId String
  at         DateTime @default(now())
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@unique([storyId, customerId])
}

model Favorite {
  id           String    @id @default(cuid())
  customerId   String
  restaurantId String
  createdAt    DateTime  @default(now())
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([customerId, restaurantId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info")
  icon      String   @default("🔔")
  read      Boolean  @default(false)
  orderId   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════
//  FEATURES INNOVADORAS
// ═══════════════════════════════════════════════════════════════════

// ─── Antojo Wallet (billetera digital) ───
model Wallet {
  id          String   @id @default(cuid())
  customerId  String   @unique
  balance     Int      @default(0)
  createdAt   DateTime @default(now())
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String   // topup | purchase | cashback | bonus
  amount      Int      // positivo = entra, negativo = sale
  description String
  orderId     String?
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

// ─── Chef's Drops (platos edición limitada) ───
model ChefDrop {
  id            String   @id @default(cuid())
  restaurantId  String
  menuItemId    String
  name          String
  description   String
  emoji         String
  price         Int
  stock         Int
  sold          Int      @default(0)
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

// ─── Reseña con foto ───
model ReviewPhoto {
  id          String   @id @default(cuid())
  reviewId    String
  imageUrl    String
  createdAt   DateTime @default(now())
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// ─── Misión Diaria ───
model DailyMission {
  id          String   @id @default(cuid())
  customerId  String
  date        DateTime
  type        String   // veggie | new_restaurant | reorder | streak | spicy
  title       String
  description String
  icon        String
  reward      Int      // coins
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── Domiciliario del Mes (leaderboard) ───
model DriverLeaderboard {
  id            String   @id @default(cuid())
  driverId      String
  month         String   // "2025-07"
  deliveries    Int      @default(0)
  rating        Float    @default(0)
  earnings      Int      @default(0)
  bonusEarned   Int      @default(0)
}

// ─── Antojo For Business ───
model BusinessAccount {
  id            String   @id @default(cuid())
  companyName   String
  contactEmail  String   @unique
  stipendPerEmployee Int  @default(200000) // mensual
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  employees     BusinessEmployee[]
}

model BusinessEmployee {
  id            String   @id @default(cuid())
  businessId    String
  userId        String   @unique
  monthlyStipend Int     @default(200000)
  usedThisMonth  Int      @default(0)
  business      BusinessAccount @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ─── Eco-Antojo (huella de carbono) ───
model EcoStat {
  id            String   @id @default(cuid())
  orderId       String   @unique
  co2SavedKg    Float    @default(0) // CO2 ahorrado vs manejar
  treesAccumulated Int   @default(0)
  createdAt     DateTime @default(now())
}
